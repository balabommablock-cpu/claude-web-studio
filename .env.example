# ============================================
# Claude Web Studio — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================

# --- DATABASE (Supabase) ---
# Get from: https://supabase.com → New Project → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- AUTH (Clerk) ---
# Get from: https://clerk.com → Create Application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- PAYMENTS (Stripe) ---
# Get from: https://stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
# Set up webhook at: https://stripe.com → Developers → Webhooks → Add endpoint
# URL: https://yourdomain.com/api/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.deleted, invoice.payment_failed

# --- ANALYTICS (PostHog) ---
# Get from: https://posthog.com → Project Settings → API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_KEY=phc_xxxxxxxxxxxxx

# --- EMAIL (Resend) ---
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# --- ERROR TRACKING (Sentry) ---
# Get from: https://sentry.io → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxx@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxx

# --- DEPLOYMENT (Vercel) ---
# Get from: https://vercel.com → Settings → Tokens
VERCEL_TOKEN=xxxxxxxxxxxxx

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=YourAppName
